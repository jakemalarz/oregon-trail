{
  "name": "oregon-trail",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "1985 Oregon Trail - HTML/JS/CSS recreation",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "lint": "eslint . --ext .ts,.tsx && tsc --noEmit",
    "package": "npm run build && cd dist && zip -r ../oregon-trail-dist.zip . && cd .."
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^2.1.1",
    "eslint": "^8.57.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "vitest": "^2.1.1"
  }
}
